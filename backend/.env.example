# Copy to .env and adjust values.

# PostgreSQL (SQLAlchemy 2 + psycopg3 driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/urms

SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Google Sign-In: must match the frontend REACT_APP_GOOGLE_CLIENT_ID exactly
# (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client)
GOOGLE_CLIENT_ID=663794777784-654bi9re2fq3labasmkkjle8uoufit1f.apps.googleusercontent.com

# Optional: YOU choose email + password; seed script creates this admin if not present
# (run after migrations: python -m app.db.seed)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Email reminders (due tomorrow); leave empty to use in-app notifications only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Daily reminder job hour (UTC)
REMINDER_HOUR_UTC=8
